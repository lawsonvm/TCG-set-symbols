    <div class="settings-manager-page settings-manager-settings-page">
        <div class="settings-manager__content">
            <div class="settings-manager__animated-menu-first-part">
                <div class="settings-manager__content-item settings-manager__content-item-back">
                    <div class="settings-manager__content-item-back__wrapper settings-manager__settings-toggle">
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.66667 16.6654L13.3631 10.3628C13.5729 10.1654 13.5729 9.83202 13.3631 9.6346L6.66667 3.33203" stroke="#2E353F" stroke-linecap="round"></path>
</svg>

                      <span class="settings-manager__text">Back</span>
                    </div>
                </div>
                <div class="settings-manager__content-item">
                    <label class="switch__container">
                        <label class="settings-manager__text" for="toggle-lock-position">Lock position</label>
                        <input id="toggle-lock-position" type="checkbox" class="switch__checkbox">
                        <span class="switch__slider"></span>
                    </label>
                </div>
                <div class="settings-manager__content-item">
                    <label class="switch__container">
                        <label class="settings-manager__text" for="toggle-dont-show">Don’t show icon on this domain</label>
                        <input id="toggle-dont-show" type="checkbox" class="switch__checkbox">
                        <span class="switch__slider"></span>
                    </label>
                </div>
                <div class="settings-manager__content-item">
                    <label class="switch__container" for="toggle-dont-show-all-domains">
                        <div class="tooltip__container">
                            <label class="settings-manager__text" for="toggle-dont-show-all-domains">Disable Icon on All Websites</label>
                            <div class="tooltip__container-icon-wrapper">
                                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="9" cy="9" r="7" stroke="#7B8998"></circle>
    <circle cx="9" cy="12.75" r="0.75" transform="rotate(180 9 12.75)" fill="#7B8998"></circle>
    <path d="M6.75 7.125C6.75 5.88236 7.75736 4.875 9 4.875C10.2426 4.875 11.25 5.88236 11.25 7.125C11.25 7.70755 11.0286 8.2384 10.6654 8.63798C9.96882 9.40424 9 10.2145 9 11.25V11.25" stroke="#7B8998"></path>
</svg>
                                <div class="tooltip__container-text _toggle-dont-show-all-domains">Hides the icon on all websites until reactivated. You can turn it back on anytime in the app settings.</div>
                            </div>
                        </div>
                        <input id="toggle-dont-show-all-domains" type="checkbox" class="switch__checkbox">
                        <span class="switch__slider"></span>
                    </label>
                </div>
            </div>
            <div class="settings-manager__animated-menu-second-part">
                <div class="settings-manager__content-item">
                    <label class="switch__container" for="toggle-reduce-size">
                        <div class="tooltip__container">
                            <label class="settings-manager__text" for="toggle-reduce-size">Reduce Icon Size (Dot Mode)</label>
                            <div class="tooltip__container-icon-wrapper">
                                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="9" cy="9" r="7" stroke="#7B8998"></circle>
    <circle cx="9" cy="12.75" r="0.75" transform="rotate(180 9 12.75)" fill="#7B8998"></circle>
    <path d="M6.75 7.125C6.75 5.88236 7.75736 4.875 9 4.875C10.2426 4.875 11.25 5.88236 11.25 7.125C11.25 7.70755 11.0286 8.2384 10.6654 8.63798C9.96882 9.40424 9 10.2145 9 11.25V11.25" stroke="#7B8998"></path>
</svg>
                                <div class="tooltip__container-text _toggle-reduce-size">Reduces the icon to a small dot when idle. It expands on hover and can be turned off anytime in the app settings.</div>
                            </div>
                        </div>
                        <input id="toggle-reduce-size" type="checkbox" class="switch__checkbox">
                        <span class="switch__slider"></span>
                    </label>
                </div>
                <div class="settings-manager__content-item">
                    <button id="reset-position" class="settings-manager__action-button">
                        <span>Reset Position</span>
                        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect width="18" height="18" rx="9" fill="#0BBE1D"></rect>
    <path d="M7.5 12.3L4.5 9.3L5.55 8.25L7.5 10.2L12.45 5.25L13.5 6.3L7.5 12.3Z" fill="white"></path>
</svg>
                    </button>
                </div>
            </div>
        </div>    
    </div>

        
    <div class="settings-manager-page settings-manager-main-page">
        <div class="settings-manager__content">
            <div class="settings-manager__ads-count-wrapper">
                <div class="settings-manager__ads-count">
                    <span class="settings-manager__ads-count-title">Total ads blocked</span>
                    <span class="settings-manager__ads-counter" id="ads-count-text">36461</span>
                </div>
            </div>
            <div class="settings-manager-main-page__animated-contend">
                <div class="settings-manager__content-item">
                    <label class="switch__container">
                         <div class="tooltip__container">
                            <label class="settings-manager__text" for="toggle-enabled">Block ads on this website</label>
                            <div class="tooltip__container-icon-wrapper _toggle-enabled">
                                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="9" cy="9" r="7" stroke="#7B8998"></circle>
    <circle cx="9" cy="12.75" r="0.75" transform="rotate(180 9 12.75)" fill="#7B8998"></circle>
    <path d="M6.75 7.125C6.75 5.88236 7.75736 4.875 9 4.875C10.2426 4.875 11.25 5.88236 11.25 7.125C11.25 7.70755 11.0286 8.2384 10.6654 8.63798C9.96882 9.40424 9 10.2145 9 11.25V11.25" stroke="#7B8998"></path>
</svg>
                                <div class="tooltip__container-text __toggle-enabled">Ad blocking is disabled here to keep this site working properly.</div>
                            </div>
                        </div>
                        <input id="toggle-enabled" type="checkbox" class="switch__checkbox">
                        <span class="switch__slider"></span>
                    </label>
                </div>
                <div class="settings-manager__content-item">
                    <button id="report-add" class="settings-manager__action-button">
                        <span>Report ads</span>
                        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect width="18" height="18" rx="9" fill="#0BBE1D"></rect>
    <path d="M7.5 12.3L4.5 9.3L5.55 8.25L7.5 10.2L12.45 5.25L13.5 6.3L7.5 12.3Z" fill="white"></path>
</svg>
                    </button>
                </div>
                <div class="settings-manager__content-item">
                    <a id="fqa-link" href="https://support.adblock360.com/hc/en-us/categories/25372668929042" class="settings-manager__link" target="_blank">
                        <span class="settings-manager__text">FAQs</span>
                        <div class="settings-manager__open">
                          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M10.7291 4.16602H7.16663C5.50977 4.16602 4.16663 5.50916 4.16663 7.16602V12.8327C4.16663 14.4895 5.50977 15.8327 7.16663 15.8327H12.8333C14.4901 15.8327 15.8333 14.4895 15.8333 12.8327V9.27018" stroke="#2E353F" stroke-linecap="round"></path>
    <path d="M10 10L16.25 3.75" stroke="#2E353F" stroke-linecap="round"></path>
    <path d="M16.6667 7.5V3.83333C16.6667 3.55719 16.4428 3.33333 16.1667 3.33333H12.5" stroke="#2E353F" stroke-linecap="round"></path>
</svg>

                        </div>
                      
                    </a>
                </div>
                <div class="settings-manager__content-item">
                    <div class="settings-manager__settings settings-manager__settings-toggle">
                        <span class="settings-manager__text">Settings</span>
                        <div class="settings-manager__arrow"><svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.66667 16.6654L13.3631 10.3628C13.5729 10.1654 13.5729 9.83202 13.3631 9.6346L6.66667 3.33203" stroke="#2E353F" stroke-linecap="round"></path>
</svg>
</div>
                    </div>
                </div>
                <div id="howItWorks" class="settings-manager__content-item hidden">
                    <div class="settings-manager__settings settings-manager__how-it-works">
                        <span class="settings-manager__text">How it works</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    </div>
</div></template></settings-manager><style>@import url('https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,100..900&display=swap');</style></body><grammarly-desktop-integration data-grammarly-shadow-root="true"><template shadowrootmode="open"><style>
      div.grammarly-desktop-integration {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
        -moz-user-select: none;
        -webkit-user-select: none;
        -ms-user-select:none;
        user-select:none;
      }

      div.grammarly-desktop-integration:before {
        content: attr(data-content);
      }
    </style><div aria-label="grammarly-integration" role="group" tabindex="-1" class="grammarly-desktop-integration" data-content="{&quot;mode&quot;:&quot;limited&quot;,&quot;isActive&quot;:false,&quot;isUserDisabled&quot;:false}"></div></template></grammarly-desktop-integration></html>
