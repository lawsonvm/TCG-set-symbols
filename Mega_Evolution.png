    .hidden {
      display: none;
    }
    .disable {
      visibility: hidden;
      pointer-events: none;
    }
    
    .settings-manager-wrapper *,
    .settings-manager-wrapper {
        font-family: "Inter", sans-serif;
        font-size: 12px;
        font-style: normal;
        font-weight: 400;
        line-height: 18px;
        color: #0B1936;
        
        margin: 0;
        padding: 0;
        background-color: transparent;
        box-shadow: none;
        width: revert;
        text-decoration: none;
    }

    .settings-manager-wrapper {
        opacity: 0;
        position: fixed;
        width: auto;
        margin: 0;
        padding: 0;
        border-radius: 20px;
        z-index: 10000000;
        direction: ltr;
    }
    
    .settings-manager-wrapper.activated {
      opacity: 1;
    }

    .settings-manager-wrapper.hidden {
      display: none !important;
    }

    .settings-manager-page {
        width: 281px;
      
        &.active {
            opacity: 1;
            z-index: initial;
            pointer-events: initial;
        }
    }

    .active {
        display: block !important;
    }
    
    .nonVisible {
        opacity: 0 !important;
    }

    .settings-manager__content {
        display: flex;
        flex-direction: column;
        background-color: #FFF;    
        border-bottom-right-radius: 8px;
        border-bottom-left-radius: 8px;
    }
    
    .settings-manager__ads-count-wrapper {
        padding: 5px 16px;
    }
    
    .settings-manager__ads-count {
        display: flex;
        justify-content: center;
        align-items: center;
        flex-direction: column;
        background: #B3C0C8;
        padding: 8px 12px;
        border-radius: 6px;
    }

    .settings-manager-toggle-button-wrapper:has(.settings-manager__toggle-button.active) + .settings-manager-menu .settings-manager__ads-count {
        background: #1B86FA;
    }

    .settings-manager__ads-count-title {
      color: #FFF;
      font-weight: 700;
      font-size: 10px;
      line-height: 18px;
      text-align: center;
      text-transform: uppercase;
    }

    .settings-manager__ads-counter {
        color: #FFF;
        font-weight: 400;
        font-size: 18px;
        line-height: 30px;
        text-align: center;
        vertical-align: middle;
    }
    
    .settings-manager__content-item {
        transition: background-color 0.3s ease;
        position: relative;
    }
    
    .settings-manager__content-item > :first-child {
        padding: 6px 16px;
        width: 100%;
        display: flex;
        box-sizing: border-box;
        height: 38px;
        align-items: center;
        cursor: pointer;
        justify-content: space-between;
    }

    .settings-manager__content-item:hover {
        background-color: #F3F5F5;
    }
    
    .settings-manager__content-item:has(button:disabled) {
        opacity: .3;
        pointer-events: none;
    }

    .settings-manager__content-item:has(.settings-manager__action-button--active:disabled) {
        background-color: #0BBE1D1A !important;
        opacity: 1;
    }

    .settings-manager__content-item:has(input:disabled) {
      .switch__container {
        cursor: default;
      }
        cursor: default;
        &:hover {
          background-color: transparent;
        }
    }

    .settings-manager__action-button {
        width: 100%;
        border: none;
        outline: none;
        text-align: left;
    }

    .settings-manager__text[for="toggle-enabled"] {
        display: inline-flex;
    }

    .settings-manager__action-button svg, 
    .settings-manager__action-button rect {
        width: 18px;
    }

    .settings-manager__action-button svg {
        margin-right: 9px;
        display: none;
    }

    .settings-manager__action-button.show-icon svg {
        display: revert;
    }

    .settings-manager__link-wrapper {
        display: flex;
    }

    .switch__container {
        position: relative;
        display: inline-flex;
        align-items: center;
        width: 100%;
    }

    .switch__slider {
        display: block;
    }

    .switch__checkbox {
        opacity: 0;
        width: 0;
        height: 0;
        position: absolute;
    }

    .switch__slider {
        position: relative;
        width: 36px;
        height: 20px;
        background-color: #B3C0C8;
        border-radius: 12px;
        transition: background-color 0.3s;
        display: inline-block;
    }

    .switch__slider::before {
        content: '';
        position: absolute;
        width: 16px;
        height: 16px;
        background-color: #FFF;
        border-radius: 50%;
        top: 50%;
        transform: translateY(-50%);
        left: 1px;
        transition: transform 0.3s;
        border: 1px solid #bababa;
        z-index: 10;
    }

    .switch__checkbox:checked + .switch__slider {
        background-color: #0BA43F;
    }

    .switch__checkbox:checked + .switch__slider::before {
        transform: translate(16px, -50%);
        border-color: #0BA43F;
    }
    
    .switch__slider::after {
        content: '';
        position: absolute;
        width: 40px;
        height: 40px;
        background-color: #0BA43F;
        border-radius: 50%;
        top: 50%;
        transform: translate(-10px, -50%);
        pointer-events: none;
        z-index: 5;
        opacity: 0;
        transition: transform 0.3s ease, opacity 0.3s ease;
    }

    .switch__slider:hover::after {
        opacity: 0.08;
    }

    .switch__checkbox:checked + .switch__slider::after {
        transform: translate(6px, -50%);
    }
    
    .settings-manager__arrow,  .settings-manager__open {
        width: 20px;
        height: 20px;
    }
    
    .switch__container label {
        cursor: pointer;
    }
    
    .switch__container:has(input:disabled) .switch__slider {
        pointer-events: none;
        opacity: 0.3;
    }

    .switch__container:has(input:disabled) label {
        pointer-events: none;
    }

    .settings-manager-snackbar {
        position: fixed;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        background: #322f35;
        color: #fff;
        padding: 14px 10px;
        border-radius: 8px;
        font-size: 14px;
        line-height: 21px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        z-index: 1000;
        transition: opacity 0.3s;
        opacity: 1;
    }

   

    .settings-manager-icon {
        display: flex;
        justify-content: flex-start;
        pointer-events: none;
    }

    .settings-manager-menu:has(#howItWorks:not(.hidden)) {
      height: 290px;
    }

    .settings-manager-wrapper .settings-manager-menu:has(.active-settings-page) {
      height: 247px !important;
      transition: 0.5s;
    }
    
    .settings-manager-main-page__animated-contend {
        border-bottom-right-radius: 8px;
        border-bottom-left-radius: 8px;
        overflow: hidden;
    }

    .settings-manager-wrapper[class*="_step-"]:not([class*="_step-finish"])  .settings-manager-menu.active {
        z-index: 15;
        pointer-events: none;
    }

    .settings-manager-wrapper[class*="_step-"]:not([class*="_step-finish"]) .settings-manager__content,
    .settings-manager-wrapper[class*="_step-"]:not([class*="_step-finish"]) .settings-manager-menu__logo {
        background-color: #05172F30;
    }

    .settings-manager-wrapper[class*="_step-"]:not([class*="_step-finish"]) .settings-manager-main-page__animated-contend {
        overflow: revert;
    }

    ._step-4 .settings-manager-main-page {
      display: none;
    }

    ._step-2 .settings-manager-menu,
    ._step-3 .settings-manager-menu,
    ._step-4 .settings-manager-menu {
      display: block !important;
      z-index: 15;
    }

    ._step-2 .settings-manager-menu,
    ._step-3 .settings-manager-menu {
      pointer-events: none;
    }

    ._step-4 .settings-manager-menu {
      pointer-events: revert;
    }

    .settings-manager-toggle-button-wrapper {
        display: flex;
        align-items: center;
    }

    .settings-manager-toggle-button-wrapper.active {
      display: flex !important;
    }

    .js-active-ad-blocking-icon,
    .js-disabled-ad-blocking-icon {
      display: none;
    }

    .settings-manager__toggle-button {
        width: 68px;
        height: 36px;
        opacity: 0;
        margin: 0;
        outline: 0;
        border: none;
        cursor: pointer;
        display: flex;
        justify-content: flex-start;
        border-bottom-left-radius: 18px;
        border-top-left-radius: 18px;
        box-shadow: 0 4px 20px 0  #00000026;;

        position: relative;
        transform-origin: right;
        transition: 0.3s;
        padding: 1px 8px 1px 6px;

        &::before {
            content: '';
            position: absolute;
            inset: 0;
            opacity: 0;
            transition: 0.3s;
            z-index: -1;
    
            border-bottom-left-radius: 18px;
            border-top-left-radius: 18px;
        }

        &.active {
            display: flex !important;
            background: #5677AA4D;

            .js-active-ad-blocking-icon {
                display: block;
            }
        }
      
        &:not(.active) {
            background: #2020204D;

            .js-disabled-ad-blocking-icon {
                display: block;
            }
        }
    }

    .settings-manager__toggle-button.settings-manager__toggle-button_dot-mod.active:hover::before {
      opacity: 0;
    }

    .settings-manager__toggle-button.settings-manager__toggle-button_dot-mod:not(.active):hover::before {
      opacity: 0;
    }
    
    .settings-manager__toggle-button.active:hover::before,
    .settings-manager-toggle-button-wrapper:has(+ .active) .settings-manager__toggle-button.active::before {
        opacity: 1;
        background: linear-gradient(90deg, #192536 0%, #283E5D 71.01%);
    }

    .settings-manager-toggle-button-wrapper:has(+ .active) .settings-manager-dot-mod,
    [class*="_step-"]:not([class*="_step-finish"]) .settings-manager-dot-mod {
      transform: translateX(60px)
    }
    
    .settings-manager__toggle-button:not(.active):hover::before,
    .settings-manager-toggle-button-wrapper:has(+ .active) .settings-manager__toggle-button:not(.active)::before {
        opacity: 1;
        background: linear-gradient(90deg, #606268 0%, #797C88 71.01%);;
    }

    .settings-manager__toggle-button:hover:not(.settings-manager__toggle-button_dot-mod),
    .settings-manager-toggle-button-wrapper:has(+ .settings-manager-menu.active) .settings-manager__toggle-button {
      transform: translateX(-24px) !important;
    }

    .settings-manager-toggle-button-wrapper:has(+ .settings-manager-menu.active) .settings-manager__toggle-button {
      transition: .3s;
    }

    .settings-manager-wrapper[class*="_step-"]:not([class*="_step-finish"]) .settings-manager__toggle-button {
        z-index: 15;
        pointer-events: none;
    }

  .settings-manager-menu {
      position: absolute;
      display: none;
      width: 281px;
      min-height: 246px;
      box-shadow: 0 4px 12px 0  #00000026;;
      border-radius: 8px;
      background-color: #FFF;
      bottom: 0;
  }
  
  .settings-manager-toggle-button-wrapper_side-right + .settings-manager-menu {
      right: calc(100% + 31px);
  }

  .settings-manager-toggle-button-wrapper_side-left + .settings-manager-menu {
      left: calc(100% + 31px);
  }

  .settings-manager-toggle-button-wrapper_side-right + .settings-manager-menu_top {
     bottom: revert;
      top: 0;
  }
  
  .settings-manager-wrapper[class*="_step-"]:not([class*="_step-finish"]) .settings-manager-menu_top {
      top: revert;
      bottom: 0;
  }

  .settings-manager-toggle-button-wrapper_side-left + .settings-manager-menu_top {
      top: 0;
  }

  .settings-manager-menu__logo {
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 6px 0;
      background: #F3F5F5;
      border-top-right-radius: 8px;
      border-top-left-radius: 8px;
  }

  .settings-manager-menu__logo svg {
      width: 85px;
  }

  .settings-manager-menu > svg {
      display: block;
      margin: 0 auto;
  }

  .settings-manager-settings-page {
      position: absolute;
      z-index: -1;
      display: block;
      pointer-events: none;
      width: 281px;
      opacity: 0;
      transition: .5s;
  }
  
  .settings-manager__content-item-back {
      height: 30px;
      background-color: #09142B;
      transition: background-color 0.2s ease;
  }
  
  .settings-manager__content-item-back:hover {
      background-color: #005DD8;
      transition: background-color 0.2s ease;
  }

  .settings-manager__content-item-back .settings-manager__text {
      color: #FFF !important;
  }

  .settings-manager__content-item-back svg {
      transform: rotate(180deg);
      margin-left: -5px;
  }

  .settings-manager__content-item-back svg path {
      stroke: #FFF;
  }
  
  .settings-manager__content-item-back__wrapper {
      height: 30px !important;
      justify-content: flex-start !important;
      gap: 5px;
  }
  /* Custom select можно вынести отдельно */
  .custom-select {
      position: relative;
  }

  .custom-select-box {
      position: relative;
      font-size: 14px;
      border-radius: 4px;
      background-color: transparent;
      cursor: pointer;
      width: 135px;
      height: 30px;

      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 10px;
      padding-right: 9px;
  }

  .settings-manager__text {
      cursor: pointer;
  }
  
  .custom-select-box-active {
      font-size: 14px;  
      color: #7B8998;
  }
  
  .custom-select-box-arrow {
      width: 20px;
      height: 20px;
      transform: rotate(90deg);
  }

  .custom-select-options {
      position: absolute;
      top: -50px;
      left: 0;
      width: 100%;
      background-color: white;
      border-radius: 4px;
      box-shadow: 0 2px 4px 0  #00000026;;
      display: none;
      max-height: 200px;
      overflow-y: auto;
      z-index: 15;
      padding: 4px 0;
  }
  
  .custom-select-option {
      position: relative;
      padding: 8px 12px;
      font-size: 14px;
      cursor: pointer;
      display: flex;
      gap: 12px;
  }

  .custom-select-option[data-value="custom"] {
      display: none;
  }
  
  .custom-select-box.open > .custom-select-options {
      display: block;
  }
  
  .custom-select-option:hover {
      background-color: #67C8FF1A;
  }
  
  .custom-select-option--active:after {
      content: '';
      display: block;
      width: 20px;
      height: 20px;
      background-image: url('data:image/svg+xml;base64,');
      background-size: contain;
      background-repeat: no-repeat;
  }
  
  .settings-manager-menu:has(.active-settings-page) .settings-manager-main-page {
     position: absolute;
     opacity: 0;
     pointer-events: none;
     transition: .5s;
     height: 220px;
     overflow: hidden;
  }
  .settings-manager-menu:has(.active-settings-page) .settings-manager-main-page .settings-manager-main-page__animated-contend {
    opacity: 0;
  }
  
  .settings-manager__animated-menu-second-part .settings-manager__content-item:last-child,
  .settings-manager__animated-menu-second-part .settings-manager__content-item:last-child .settings-manager__action-button{
    overflow: hidden;
    border-bottom-left-radius: 8px;
    border-bottom-right-radius: 8px;
  }
  
  .settings-manager__animated-menu-second-part {
    border-bottom-left-radius: 8px;
    border-bottom-right-radius: 8px;
  }

  ._step-4 .settings-manager-settings-page {
    border-bottom-left-radius: 8px;
    border-bottom-right-radius: 8px;
    /*overflow: hidden;*/
  }
  
  ._step-4 .settings-manager__animated-menu-second-part .settings-manager__content-item:last-child,
  ._step-4 .settings-manager__animated-menu-second-part .settings-manager__content-item:last-child .settings-manager__action-button {
    overflow: revert !important;
  }

  .highlighted {
    filter: drop-shadow(0px 0px 12px  #67C8FF);
    background-color: #FFF;
  }
  
  .settings-manager-main-page__animated-contend:has( > .highlighted) {
    overflow: initial;
  }

    .settings-manager-settings-page {
        opacity: 0;
    }

    .settings-manager-settings-page .settings-manager__content {
        background: transparent;
    }

    .settings-manager-settings-page
    .settings-manager__animated-menu-first-part,
    .settings-manager-settings-page
    .settings-manager__animated-menu-second-part,
    .settings-manager-settings-page
    .settings-manager__content-item:not(.settings-manager__content-item.settings-manager__content-item-back) {
        background: #FFF;
    }

    .settings-manager-settings-page
    .settings-manager__animated-menu-first-part {
        z-index: 1001;
    }

    .settings-manager-settings-page
    .settings-manager__animated-menu-second-part {
      z-index: 1002;
    }

    .active-settings-page.settings-manager-settings-page {
        z-index: 11;
        pointer-events: initial;
        opacity: 1;
    }

    /* === Анимации входа === */
    .active-settings-page .settings-manager__animated-menu-first-part {
        animation: fadeSlideFirstIn 0.4s forwards;
    }

    .active-settings-page .settings-manager__animated-menu-second-part {
        animation: fadeSlideSecondIn 0.4s forwards;
    }

    .settings-manager-menu:has(.settings-manager-main-page.active-main-page)
    .settings-manager__animated-menu-first-part {
        animation: hideSettingsPageFirstPart 0.4s ease-out forwards;
    }

    .settings-manager-menu:has(.settings-manager-main-page.active-main-page)
    .settings-manager__animated-menu-second-part {
        animation: hideSettingsPageSecondPart 0.4s ease-out forwards;
    }

    .settings-manager-menu:has(.settings-manager-main-page.active-main-page) .settings-manager__ads-count-wrapper {
        animation: showBlockedCount 0.2s ease-in forwards;
    }

    .settings-manager-menu:has(.settings-manager-main-page.active-main-page) .settings-manager-main-page__animated-contend {
        animation: showMainPageSettings .7s ease-in forwards;
    }

    @keyframes fadeSlideFirstIn {
        from {
            transform: translateY(40px);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    @keyframes fadeSlideSecondIn {
        from {
            transform: translateY(-5px);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }
    
    @keyframes hideSettingsPageSecondPart {
        from {
            transform: translateY(10px);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    @keyframes hideSettingsPageFirstPart {
        from {
            transform: translateY(0);
            opacity: 1;
        }
        to {
            transform: translateY(80px);
            opacity: 0;
        }
    }

    @keyframes showBlockedCount {
        from {
            transform: translateY(10px);
            opacity: .5;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    @keyframes showMainPageSettings {
        0% {
            transform: translateY(-30px);
            opacity: 0;
        }

        50% {
            transform: translateY(5px);
            opacity: 1;
        }

        75% {
            transform: translateY(-2px);
        }

        100% {
            transform: translateY(0);
        }
    }

    .settings-manager-toggle-button-wrapper_dragged{
        .settings-manager-dot-mod {
          visibility: hidden;
          transition: visibility 0s linear 0s;
        }

        .settings-manager__toggle-button, .settings-manager__toggle-button::before {
            width: 40px;
            height: 40px;
            border-radius: 50% !important;
            opacity: 1 !important;
        }

        .settings-manager-icon {
            flex-direction: row-reverse;
            margin-left: -1px;
            margin-top: 2px;
        }
    }

    .settings-manager-dot-mod {
        position: absolute;
        width: 10px;
        height: 10px;
        border: 2px solid #FFF;
        background: #005DD8;
        border-radius: 50%;
        box-shadow: 0 2px 4px 0 #05172F4D;
        transition: transform 0.3s ease-in-out 0.15s, visibility 0s linear 0.25s;
        
        &::before {
            content: '';
            display: block;
            width: 55px;
            height: 32px;
            background: transparent;
            position: absolute;
            z-index: -1;
            left: -11px;
            top: -11px;
        }
    }

    .settings-manager-toggle-button-wrapper {
        &:not(:has(.settings-manager__toggle-button.active)) .settings-manager-dot-mod {
            background-color: #2020204D;
        }

        &.settings-manager-toggle-button-wrapper_side-right:hover .settings-manager__toggle-button_dot-mod {
                transform: translateX(-4px);
        }

        /*&.settings-manager-toggle-button-wrapper--side-right.active .settings-manager-dot-mod {*/
        /*    transform: translateX(60px);*/
        /*}*/

        &.settings-manager-toggle-button-wrapper_side-left {
            &:hover .settings-manager__toggle-button_dot-mod {
                transform: translateX(-4px);
            }

            .settings-manager-dot-mod {
                transform: translateX(12px);
            }

            & {
              transform: scaleX(-1);
            }

            &.active .settings-manager-dot-mod {
                transform: translateX(60px) !important;
            }
        }

        &:hover .settings-manager-dot-mod.settings-manager-dot-mod[class][class] {
            transform: translateX(60px);
        }
    }

    .settings-manager__toggle-button_dot-mod {
        transition: transform 0.3s ease-in-out 0.2s;
        transform: translateX(44px);
    }
  
    .settings-manager-toggle-button-wrapper:has(+ .active) .settings-manager-toggle-button-wrapper_side-right .settings-manager__toggle-button_dot-mod {
          transform: translateX(-38px);
    }

    .settings-manager-toggle-button-wrapper_dragged {
        cursor: grab !important;
    }

    .settings-manager-toggle-button-wrapper_dragged .settings-manager__toggle-button[class][class] {
        pointer-events: none !important;
        cursor: grab !important;
        transform: none !important;
    }

    .settings-manager-toggle-button-wrapper_dragged .settings-manager__toggle-button.active::before {
        background: linear-gradient(90deg, #192536 0%, #283E5D 71.01%);
    }

    .settings-manager-toggle-button-wrapper_dragged .settings-manager__toggle-button:not(.active)::before {
        background: linear-gradient(90deg, #606268 0%, #797C88 71.01%);;
    }

    .tooltip__container {
      display: flex;
      align-items: center;
      gap: 5px;
  }
  
  .tooltip__container-icon-wrapper {
      cursor: pointer;
      width: 18px;
      height: 18px;
  }
  
  .tooltip__container-icon-wrapper._toggle-enabled {
    display: none;
  }
  
  .tooltip__container-icon-wrapper:hover > svg path {
      stroke: #005DD8;
  }

  .tooltip__container-icon-wrapper:hover > svg circle:first-child {
      stroke: #005DD8;
  }

  .tooltip__container-icon-wrapper:hover > svg circle:nth-child(2) {
      fill: #005DD8;
  }

  .tooltip__container-text {
      box-sizing: border-box;
      font-family: "Manrope", sans-serif;
      cursor: default;
      font-size: 12px;
      line-height: 16px;
      max-width: 216px;
      letter-spacing: 0.16px;
      color: #FFF;
      background-color: #09142B;
  
      border-radius: 4px;
      padding: 4px 12px 6px 12px;
  
      position: absolute;
      top: -50px;
      left: 54px;
  
      visibility: hidden;
      z-index: -15;
      transition-delay: 0.5s;
  
      box-shadow: 0 2px 4px 0  #00000026;;

      &._toggle-reduce-size {
        top: -67px;
        left: 54px;
    }
  }
  
  .tooltip__container-text.__toggle-enabled {
    top: 50px;
    left: 52px;
  }

  .tooltip__container-icon-wrapper:hover  .tooltip__container-text {
      visibility: visible;
      z-index: 15;
  }
</style><div class="settings-manager-wrapper activated" style="left: 1176px; top: 790px;">
